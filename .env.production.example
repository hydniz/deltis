# Habit Tracker – Production-Umgebungsvariablen
# Kopiere diese Datei nach .env.production und trage deine Werte ein.
# MONGODB_URI wird durch docker-compose.yml überschrieben – hier nicht nötig.

PORT=3001

# UUIDs der erlaubten Benutzer (kommagetrennt, keine Leerzeichen).
# Generiere neue UUIDs z.B. mit: uuidgen | tr '[:upper:]' '[:lower:]'
VALID_UUIDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
