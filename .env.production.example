# Habit Tracker – Production environment variables
# Copy this file to .env.production and fill in your values.
# MONGODB_URI is overridden by docker-compose.yml and does not need to be set here.

PORT=3001

# Pepper for password hashing (protects against offline attacks if the database is compromised).
# Recommended: point PEPPER_FILE to a file outside the project.
# The file must contain a long random string (e.g. generated with: openssl rand -base64 48)
# IMPORTANT: Never change it after the first user login - all passwords are hashed with it!
PEPPER_FILE=/run/secrets/habit_tracker_pepper
# Alternatively, set it directly as an environment variable (less secure, as it may be visible in the process list):
# PASSWORD_PEPPER=your_very_long_secret_here

# Legacy migration (optional): UUIDs listed here are imported as regular users on first start.
# Remove this line once migration is complete.
# VALID_UUIDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
