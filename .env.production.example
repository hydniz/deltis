# Habit Tracker – Production environment variables
# Copy this file to .env.production and fill in your values.
# MONGODB_URI is overridden by docker-compose.yml and does not need to be set here.

PORT=3001

# Pepper für Passwort-Hashing (schützt gegen Offline-Angriffe, falls die Datenbank kompromittiert wird).
# Empfohlen: PEPPER_FILE auf eine Datei außerhalb des Projekts zeigen lassen.
# Die Datei muss eine zufällige, lange Zeichenkette enthalten (z. B. generiert mit: openssl rand -base64 48)
# WICHTIG: Nie ändern nach dem ersten Nutzer-Login – alle Passwörter werden damit gehashed!
PEPPER_FILE=/run/secrets/habit_tracker_pepper
# Alternativ direkt als Umgebungsvariable (weniger sicher, da in Prozessliste sichtbar):
# PASSWORD_PEPPER=dein_sehr_langes_geheimnis_hier

# Legacy migration (optional): UUIDs listed here are imported as regular users on first start.
# Remove this line once migration is complete.
# VALID_UUIDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
