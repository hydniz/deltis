# Deltis – Production environment variables
# Copy this file to .env.production and fill in your values.
#
# Configuration priority (highest first):
#   1. Variables in this file / docker-compose environment: section
#   2. /etc/deltis/deltis.config.json  (written by the admin UI)
#   3. Built-in defaults
#
# MONGODB_URI:
#   Set here (highest priority) OR let the admin UI write it to deltis.config.json.
#   If set here it cannot be changed via the UI.
MONGODB_URI=mongodb://mongo:27017/habit_tracker

PORT=3001

# Number of trusted reverse-proxy hops in front of the app (e.g. 1 for a
# single nginx/Traefik/NAS proxy). Required for correct client IPs in rate
# limiting. Leave unset when clients connect directly.
# TRUST_PROXY=1

# Secret for signing JWT session tokens.
# Generate with: openssl rand -base64 64
# IMPORTANT: Changing this value invalidates ALL active sessions — every user must log in again.
#
# JWT_SECRET_FILE takes precedence over JWT_SECRET when both are set.
# Set exactly one of the two options:
#
# Option A – path to a file containing the secret (recommended for Docker secrets / NAS):
# JWT_SECRET_FILE=/run/secrets/deltis_jwt_secret
#
# Option B – value directly in env (less secure, may appear in process list):
JWT_SECRET=replace_with_a_long_random_string

# Pepper for password hashing (protects against offline attacks if the database is compromised).
# Recommended: point PEPPER_FILE to a file outside the project.
# The file must contain a long random string (e.g. generated with: openssl rand -base64 48)
# IMPORTANT: Never change it after the first user login - all passwords are hashed with it!
PEPPER_FILE=/run/secrets/habit_tracker_pepper
# Alternatively, set it directly as an environment variable (less secure, as it may be visible in the process list):
# PASSWORD_PEPPER=your_very_long_secret_here

# Legacy migration (optional): UUIDs listed here are imported as regular users on first start.
# Remove this line once migration is complete.
# VALID_UUIDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
