{
  "name": "deltis-backend",
  "version": "0.5.19",
  "stage": "",
  "apiVersion": 12,
  "scripts": {
    "dev": "concurrently \"nodemon server/index.js\" \"npm run dev --prefix client\"",
    "server:dev": "nodemon server/index.js",
    "server:start": "NODE_ENV=production node server/index.js",
    "server:test": "jest --runInBand --forceExit",
    "server:test:coverage": "jest --runInBand --forceExit --coverage",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "client:preview": "npm run preview --prefix client",
    "client:test": "npm test --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "test:all": "npm run server:test && npm run client:test",
    "admin:reset-password": "node scripts/reset-admin-password.js",
    "migrate:status": "node scripts/migration-status.js",
    "migrate:rollback": "node scripts/rollback-migration.js",
    "seed:demo": "node scripts/seed-demo.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/server/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "concurrently": "^8.2.2",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
