{
  "name": "habit-tracker",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"nodemon server/index.js\" \"npm run dev --prefix client\"",
    "start": "NODE_ENV=production node server/index.js",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
